# PostgreSQL (Isolated Test Database)
POSTGRES_DB=cinema_test_db
POSTGRES_DB_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=some_password
POSTGRES_HOST=db
DATABASE_URL=postgresql+asyncpg://admin:some_password@db/cinema_test_db
# JWT keys for Testing (Mock safe strings)
SECRET_KEY_ACCESS=test_secret_key_access_000000000000000000000000000000000000000000
SECRET_KEY_REFRESH=test_secret_key_refresh_00000000000000000000000000000000000000000
JWT_SIGNING_ALGORITHM=HS256
# Email settings for Testing (MailHog Mock)
EMAIL_HOST=mailhog
EMAIL_PORT=1025
EMAIL_HOST_USER=test@test.com
EMAIL_HOST_PASSWORD=test_password
EMAIL_USE_TLS=False
# MinIO (Test Storage Partition)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=some_password
MINIO_HOST=minio-cinema
MINIO_PORT=9000
MINIO_STORAGE=test-storage
# Celery (Using Redis DB index 1 to isolate test tasks)
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/1
# Stripe API Keys (Mocked for safety; actual endpoints are mocked during pytest)
STRIPE_SECRET_KEY=sk_test_your_stripe_test_key_here
STRIPE_WEBHOOK_SECRET=whsec_mock_00000000000000000000000000000000